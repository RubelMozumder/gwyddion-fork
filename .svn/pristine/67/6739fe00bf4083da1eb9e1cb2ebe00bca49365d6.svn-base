<informalequation id='eq-turing-function-f'>
  <mediaobject>
    <imageobject>
      <imagedata fileref='eq-turing-function-f.svg' format='SVG'/>
    </imageobject>
    <textobject role='tex'>
      <phrase>
<![CDATA[
f(x) = x\left[\frac{100}{100+x^2} - \frac{1}{100}\right]
]]>
      </phrase>
    </textobject>
  </mediaobject>
</informalequation>
