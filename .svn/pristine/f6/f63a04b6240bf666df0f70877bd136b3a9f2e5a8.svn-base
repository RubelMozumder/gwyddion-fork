#~ "><placeholder-5/></menuchoice>"
#~ msgstr ""
#~ "<indexterm><placeholder-1/></indexterm><indexterm><placeholder-2/></"
#~ "indexterm> Изменить шаг точек данных для получения заданных размеров или "
#~ "масштабировать, используя выбранный метод интерполяции "
#~ "<menuchoice><placeholder-3/><placeholder-4/><placeholder-5/></menuchoice>"

#~ msgid "Crop tool"
#~ msgstr "Инструмент кадрирования"

#~ msgid "Create new image"
#~ msgstr "Создать новое изображение"

#~ msgid "Keep lateral offsets"
#~ msgstr "Сохранять пространственные смещения"

#~ msgid "Rotate Clockwise"
#~ msgstr "Повернуть по часовой"

#~ msgid "Rotate Anticlockwise"
#~ msgstr "Повернуть против часовой"

#~ msgid "Rotate"
#~ msgstr "Поворот"

#~ msgid ""
#~ "<indexterm><placeholder-1/><placeholder-2/></"
#~ "indexterm><indexterm><placeholder-3/><placeholder-4/></indexterm> Rotate "
#~ "data by 90 degrees or by user-specified amount using some of the rotate "
#~ "functions: <menuchoice><placeholder-5/><placeholder-6/><placeholder-7/></"
#~ "menuchoice>, <placeholder-8/> or <placeholder-9/>."
#~ msgstr ""
#~ "<indexterm><placeholder-1/><placeholder-2/></"
#~ "indexterm><indexterm><placeholder-3/><placeholder-4/></indexterm> "
#~ "Повернуть данные на угол, кратный прямому или на произвольно заданный "
#~ "можно с помощью одной из функций поворота: <menuchoice><placeholder-5/"
#~ "><placeholder-6/><placeholder-7/></menuchoice>, <placeholder-8/> или "
#~ "<placeholder-9/>."

#~ msgid "Flip Horizontally"
#~ msgstr "Перевернуть горизонтально"

#~ msgid "Flip Vertically"
#~ msgstr "Перевернуть вертикально"

#~ msgid ""
#~ "<indexterm><placeholder-1/><placeholder-2/></"
#~ "indexterm><indexterm><placeholder-3/><placeholder-4/></indexterm> Flip "
#~ "the data horizontally (i.e. about the vertical axis) and vertically (i.e. "
#~ "about the horizontal axis) with <menuchoice><placeholder-5/"
#~ "><placeholder-6/><placeholder-7/></menuchoice> and <placeholder-8/>, "
#~ "respectively."
#~ msgstr ""
#~ "<indexterm><placeholder-1/><placeholder-2/></"
#~ "indexterm><indexterm><placeholder-3/><placeholder-4/></indexterm> "
#~ "Переворот данных горизонтально (т.е. относительно вертикальной оси) или "
#~ "вертикально (т.е. относительно горизонтальной оси) осуществляется с "
#~ "помощью функций <menuchoice><placeholder-5/><placeholder-6/"
#~ "><placeholder-7/></menuchoice> и <placeholder-8/>, соответственно."

#~ msgid "Flip Both"
#~ msgstr "Перевернуть оба"

#~ msgid ""
#~ "Flip the data about the centre (i.e. about both axes) with "
#~ "<menuchoice><placeholder-1/><placeholder-2/><placeholder-3/></menuchoice>."
#~ msgstr ""
#~ "Отражение данных относительно центра (т.е. относительно обеих осей) "
#~ "осуществляется с помощью функции <menuchoice><placeholder-1/"
