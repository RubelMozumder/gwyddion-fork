#~ msgstr "Порог"

#~ msgid "(0, 0)"
#~ msgstr "(0, 0)"

#~ msgid "(0,0)"
#~ msgstr "(0,0)"

#~ msgid ""
#~ "Angle <inlineequation><mathphrase><phrase role=\"mathvar\">φ</phrase></"
#~ "mathphrase><alt>\\varphi</alt></inlineequation> is the counter-clockwise "
#~ "measured angle between axis <inlineequation><mathphrase><phrase role="
#~ "\"mathvar\">x</phrase></mathphrase><alt>x</alt></inlineequation> and the "
#~ "projection of the normal to the <inlineequation><mathphrase><phrase role="
#~ "\"mathvar\">xy</phrase></mathphrase><alt>xy</alt></inlineequation> plane, "
#~ "as displayed on the following figure. For facets it means "
#~ "<inlineequation><mathphrase><phrase role=\"mathvar\">φ</phrase></"
#~ "mathphrase><alt>\\varphi</alt></inlineequation> corresponds to the "
#~ "downward direction of the facet."
#~ msgstr ""
#~ "Угол <inlineequation><mathphrase><phrase role=\"mathvar\">φ</phrase></"
#~ "mathphrase><alt>\\varphi</alt></inlineequation> - отсчитываемый против "
#~ "часовой угол между осью inlineequation><mathphrase><phrase role=\"mathvar"
#~ "\">x</phrase></mathphrase><alt>x</alt></inlineequation> и проекцией "
#~ "нормали на плоскость <inlineequation><mathphrase><phrase role=\"mathvar"
#~ "\">xy</phrase></mathphrase><alt>xy</alt></inlineequation>, как показано "
#~ "на следующем рисунке. Для граней это означает "
#~ "<inlineequation><mathphrase><phrase role=\"mathvar\">φ</phrase></"
#~ "mathphrase><alt>\\varphi</alt></inlineequation> соответствует направлению "
#~ "наклона грани."

