#~ "><placeholder-5/></menuchoice>. The values are inverted about the mean "
#~ "value which keeps the mean value unchanged."
#~ msgstr ""
#~ "<indexterm><placeholder-1/></indexterm> Инверсию данных с помощью функции "
#~ "<placeholder-2/>: <menuchoice><placeholder-3/><placeholder-4/"
#~ "><placeholder-5/></menuchoice>. Данные инвертируются относительно "
#~ "среднего, в результате среднее значение остаётся неизменным."

#~ msgid "Color range tool"
#~ msgstr "инструмент <quote>Диапазон цвета</quote>"

#~ msgid ""
#~ "<indexterm><placeholder-1/></indexterm> Tilt the data by specified "
#~ "gradient or angle using <menuchoice><placeholder-2/><placeholder-3/"
#~ "><placeholder-4/></menuchoice>."
#~ msgstr ""
