set term svg size 260,160 enhanced font 'DejaVu Sans,7' lw 0.7
load 'style.gpi'

name = 'fitfunc-gaussian-rpsdf'
set samples 201
set lmargin at screen 0.20
set rmargin at screen 0.995
set bmargin at screen 0.13
set tmargin at screen 0.99
sigma = 1
T = 1

xm = sqrt(2)/T
f(x) = (T*sigma)*2/2 * x*exp(-(x*T/2)**2)
M = f(xm)

unset grid
set key top right Left reverse samplen 1.5
set xtics out nomirror ('0' 0 0, '√2/T' xm 0)
set ytics out nomirror ('0' 0 0, 'σ²T/√2 e^{-1/2}' M 0)
set xrange [0:5]
set yrange [0:1.1*M]
set arrow from xm,0 to xm,f(xm) nohead ls 10
set arrow from 0,M to xm,f(xm) nohead ls 10
set style fill solid 0.2
set label at first 2.1/T,0.4*M 'Area = σ²' center
set output name.'.svg'

plot \
    0/0 with lines title 'Gaussian (RPSDF)' linestyle 2, \
    f(x) with filledcurves y1=0 notitle linestyle 2

