# This wrapper exists primarily because many versions of Inkscape cannot handle
# input and output files in different directories.
set -e
abs_top_srcdir="@abs_top_srcdir@"
INKSCAPE="@INKSCAPE@"
INKSCAPE_EXPORT_NEWSTYLE=@INKSCAPE_EXPORT_NEWSTYLE@
DISPLAY=
COMMON="$abs_top_srcdir/common"
cache="$COMMON/cache"
opts=
if test ! -n "$3"; then
  echo "$0 {png|pdf} INPUT.svg OUTPUT"
  exit 0
fi
fmt="$1"; shift
input="$1"; shift
output="$1"; shift
c=($(sha1sum "$input"))
c="$cache/svg-${c[0]}.$fmt"
if test -s "$c"; then
  cp "$c" "$output"
  exit 0
fi
case "$input" in
  gwy_*-24.svg) opts="$opts --export-area-page";;
  *) opts="$opts --export-area-drawing";;
esac
case "$fmt" in
  png) fopts="--export-dpi=150 --export-background=white --export-background-opacity=255";;
  pdf) fopts=;;
  *) echo "Wrong format $fmt" 1>&2; exit 1;;
esac
idir=$(dirname "$input")
ifile=$(basename "$input")
odir=$(dirname "$output")
ofile=$(basename "$output")
tmpsvg="TEMP-$fmt-$$-$ifile"
#echo idir=$idir
#echo odir=$odir
if test "$idir" != "$odir"; then
  idir=$(realpath "$idir")
  @GSED@ 's+\(xlink:href="\)\([^#][^"]*\.png"\)+\1'"$idir"'/\2+g' "$input" >"$odir/$tmpsvg"
  cd "$odir"
  if test $INKSCAPE_EXPORT_NEWSTYLE = yes; then
    @INKSCAPE@ $opts $fopts --export-type=$fmt --export-filename="$ofile" "$tmpsvg" "$@"
  else
    @INKSCAPE@ $opts $fopts --without-gui --export-$fmt="$ofile" "$tmpsvg" "$@"
  fi
  rm -f "$tmpsvg"
else
  cd "$odir"
  if test $INKSCAPE_EXPORT_NEWSTYLE = yes; then
    @INKSCAPE@ $opts $fopts --export-type=$fmt --export-filename="$ofile" "$ifile" "$@"
  else
    @INKSCAPE@ $opts $fopts --without-gui --export-$fmt="$ofile" "$ifile" "$@"
  fi
fi
test -d "$cache" || mkdir "$cache" 2>/dev/null || test -d "$cache"
cp "$ofile" "$c"
# vim: set ts=2 sw=2 et :
