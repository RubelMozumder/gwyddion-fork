set term svg size 260,160 enhanced font 'DejaVu Sans,7' lw 0.7
load 'style.gpi'

name = 'fitfunc-exponential-psdf'
set samples 201
set lmargin at screen 0.11
set rmargin at screen 0.995
set bmargin at screen 0.13
set tmargin at screen 0.99
sigma = 1
T = 1

f(x) = T*sigma**2/pi * 1/(1 + (x*T)**2)
xm = 1.0/T
M = f(0)

unset grid
set key top right Left reverse samplen 1.5
set xtics out nomirror ('0' 0 0, '1/T' xm 0)
set ytics out nomirror ('0' 0 0, 'σ²T/π' M 0)
set xrange [0:5]
set yrange [0:1.1*M]
set arrow from xm,0 to xm,f(xm) nohead ls 10
set style fill solid 0.2
set label at first 1.5*xm,0.5*f(1.5*xm) 'Area = σ²' center
set output name.'.svg'

plot \
    0/0 with lines title 'Exponential (PSDF)' linestyle 2, \
    f(x) with filledcurves y1=0 notitle linestyle 2

