<informalequation id='eq-mfm-analytical-force-transfer'>
  <mediaobject>
    <imageobject>
      <imagedata fileref='eq-mfm-analytical-force-transfer.svg' format='SVG'/>
    </imageobject>
    <textobject role='tex'>
      <phrase>
<![CDATA[
{\rm FTF}(\vec{k}) = -\frac{4\mu_0 M_t}{k_x k_y} \left(1-\e^{-kL}\right) \sin\frac{k_x b_x}{2}\,\sin\frac{k_y b_y}{2}
]]>
      </phrase>
    </textobject>
  </mediaobject>
</informalequation>
