<informalequation id='eq-mfm-stray-field-Fourier'>
  <mediaobject>
    <imageobject>
      <imagedata fileref='eq-mfm-stray-field-Fourier.svg' format='SVG'/>
    </imageobject>
    <textobject role='tex'>
      <phrase>
<![CDATA[
\begin{array}{r@{{}={}}l}
\displaystyle
A_{H_{x,y}}^{z, d}(\vec{k})
  & \displaystyle
     \im\frac{\e^{-kz}\left(1-\e^{-kd}\right)k_{x,y}}{2k}A_M(\vec{k})\\
\noalign{\smallskip}
\displaystyle
A_{H_z}^{z, d}(\vec{k})
  & \displaystyle
    \frac{\e^{-kz}\left(1-\e^{-kd}\right)}{2}A_M(\vec{k})\\
\end{array}
]]>
      </phrase>
    </textobject>
  </mediaobject>
</informalequation>
