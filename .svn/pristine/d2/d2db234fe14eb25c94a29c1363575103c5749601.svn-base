#~ msgstr "Взаимосвязь"

#~ msgid "-8"
#~ msgstr "-8"

#~ msgid "Stitching"
#~ msgstr "Сшивание"

#~ msgid "Mask by Correlation"
#~ msgstr "Пометить корреляцией"

#~ msgid "Image to be found on the base image."
#~ msgstr "Изображение, которое нужно найти в базовом."

#~ msgid "Algorithm for computing correlation can be selected here."
#~ msgstr "Здесь можно выбрать алгоритм расчёта корреляции."

#~ msgid "Detail Immersion"
#~ msgstr "Встраивание фрагмента"

#~ msgid "Merging"
#~ msgstr "Объединение"

#~ msgid "Training"
#~ msgstr "Обучение"

#~ msgid "Application"
#~ msgstr "Применение"
