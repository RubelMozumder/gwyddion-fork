#~ msgstr "Выравнивание полиномиальной линии"

#~ msgid "Levels rows or columns by fitting and subtracting polynomials."
#~ msgstr ""
#~ "Выравнивает строки и столбцы аппроксимацией полиномом и его вычетом."

