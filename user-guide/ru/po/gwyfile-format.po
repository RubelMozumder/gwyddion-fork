#: gwyfile-format.xml:177(caption)
msgid ""
"Illustration of representation of three components, integer <placeholder-1/"
">, floating point <placeholder-2/> and nested object <placeholder-3/>. They "
"would simply follow one another in the file."
msgstr ""
"Иллюстрация представления трёх компонент, целочисленного <placeholder-1/>, с "
"плавающей точкой <placeholder-2/> и вложенного объекта <placeholder-3/>. Они "
"просто будут следовать друг за другом в файле."

#: gwyfile-format.xml:187(title)
msgid "Data Types"
msgstr "Типы данных"

#: gwyfile-format.xml:188(para)
msgid "Available atomic data types are listed in following table:"
msgstr "Доступные атомарные типы данных приведены в нижеследующей таблице:"

